<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Monitory dla Pana Krzysztofa, raport premium</title>
<style>
:root {
  --bg:#0b1220;
  --paper:#0f172a;
  --ink:#e8eef8;
  --muted:#9fb0c9;
  --line:rgba(255,255,255,.08);
  --line-strong:rgba(255,255,255,.16);
  --panel:rgba(15,23,42,.86);
  --panel-2:#111b31;
  --gold:#7aa2ff;
  --gold-2:#53c5c9;
  --green:#49b88f;
  --red:#d07b86;
  --shadow:0 24px 60px rgba(0,0,0,.34);
  --radius:28px;
}
* { box-sizing:border-box; }
html, body {
  margin:0;
  background:
    radial-gradient(1100px 700px at 10% -10%, rgba(122,162,255,.18), transparent 55%),
    radial-gradient(900px 600px at 100% 0%, rgba(83,197,201,.14), transparent 52%),
    linear-gradient(180deg, #08101d 0%, #0b1220 45%, #0d1425 100%);
  color:var(--ink);
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
}
.page {
  width: min(1440px, calc(100vw - 40px));
  margin: 22px auto 48px;
}
.glass {
  background: linear-gradient(180deg, rgba(17,27,49,.88), rgba(13,20,37,.82));
  backdrop-filter: blur(16px);
  border:1px solid var(--line);
  box-shadow: var(--shadow);
}
.hero {
  position:relative;
  overflow:hidden;
  border-radius:36px;
  padding:36px 36px 30px;
  display:grid;
  grid-template-columns: 1.15fr .85fr;
  gap:24px;
}
.hero:before {
  content:"";
  position:absolute;
  inset:0;
  background:
    linear-gradient(120deg, rgba(122,162,255,.10), transparent 36%),
    radial-gradient(600px 300px at 90% 20%, rgba(83,197,201,.10), transparent 55%);
  pointer-events:none;
}
.kicker {
  display:flex; align-items:center; gap:10px;
  font-size:12px; letter-spacing:.18em; text-transform:uppercase; color:var(--muted);
}
.kicker .dot {
  width:10px; height:10px; border-radius:50%;
  background:linear-gradient(180deg, var(--gold), var(--gold-2));
  box-shadow:0 0 16px rgba(176,141,87,.45);
}
h1 {
  margin:16px 0 12px;
  font-size:clamp(34px, 4vw, 58px);
  line-height:1.02;
  letter-spacing:-.04em;
  max-width:900px;
}
.lead {
  margin:0;
  max-width:850px;
  font-size:18px;
  line-height:1.65;
  color:#dbe6f8;
}
.chips {
  display:flex; flex-wrap:wrap; gap:10px; margin-top:22px;
}
.chip {
  padding:10px 14px; border:1px solid var(--line); border-radius:999px;
  background:rgba(255,255,255,.03); color:#dbe6f8; font-size:13px;
}
.sidebox {
  display:grid; gap:16px;
}
.recommendation {
  border-radius:28px;
  padding:22px 22px 20px;
  background:linear-gradient(180deg, rgba(122,162,255,.18), rgba(83,197,201,.08));
  border:1px solid rgba(122,162,255,.22);
}
.recommendation .label {
  font-size:12px; letter-spacing:.16em; text-transform:uppercase; color:#9fb0c9;
}
.recommendation h2 {
  margin:10px 0 10px; font-size:28px; line-height:1.08; letter-spacing:-.03em;
}
.recommendation p {
  margin:0; font-size:15px; line-height:1.65; color:#d7e2f4;
}
.metric-grid {
  display:grid; grid-template-columns:repeat(3,1fr); gap:12px;
}
.metric {
  border-radius:22px; padding:16px;
  border:1px solid var(--line); background:rgba(255,255,255,.04);
}
.metric .m1 {
  font-size:12px; letter-spacing:.13em; text-transform:uppercase; color:var(--muted);
}
.metric .m2 {
  margin-top:8px; font-size:32px; font-weight:800; letter-spacing:-.04em;
}
.metric .m3 {
  margin-top:6px; font-size:13px; line-height:1.55; color:#bfd0e8;
}

.grid2 {
  display:grid;
  grid-template-columns: 1fr 1fr;
  gap:22px;
  margin-top:22px;
}
.panel {
  border-radius:30px;
  padding:26px;
}
.panel h2 {
  margin:0 0 8px; font-size:28px; line-height:1.1; letter-spacing:-.03em;
}
.panel .sub {
  margin:0; color:var(--muted); font-size:15px; line-height:1.65;
}
.bullets {
  display:grid; gap:12px; margin-top:20px;
}
.bullet {
  display:grid; grid-template-columns: 18px 1fr; gap:12px;
  padding:14px 0; border-top:1px solid var(--line);
}
.bullet:first-child { border-top:none; padding-top:6px; }
.bullet .mark {
  width:18px; height:18px; border-radius:50%; margin-top:2px;
  background:linear-gradient(180deg, var(--gold), var(--gold-2));
  box-shadow:0 0 14px rgba(176,141,87,.25);
}
.bullet b { display:block; margin-bottom:4px; font-size:15px; }
.bullet p { margin:0; color:#d7e2f4; font-size:14px; line-height:1.6; }

.section-title {
  margin:28px 0 14px;
  font-size:30px; letter-spacing:-.03em;
}
.card {
  border-radius:30px;
  padding:24px;
  margin-top:18px;
  background:linear-gradient(180deg, rgba(17,27,49,.9), rgba(13,20,37,.84));
  border:1px solid var(--line);
  box-shadow:var(--shadow);
}
.card-top {
  display:grid; grid-template-columns: 1fr 240px; gap:18px; align-items:start;
}
.badge {
  display:inline-flex; padding:8px 12px; border-radius:999px;
  font-size:11px; letter-spacing:.16em; text-transform:uppercase;
  background:rgba(122,162,255,.14); border:1px solid rgba(122,162,255,.22); color:#cfe1ff;
}
.card h3 {
  margin:12px 0 8px; font-size:30px; line-height:1.08; letter-spacing:-.03em;
}
.purpose {
  margin:0; font-size:16px; line-height:1.6; color:#d7e2f4;
}
.pricebox {
  border-radius:24px; border:1px solid var(--line); background:rgba(255,255,255,.03); padding:18px;
}
.price {
  font-size:34px; font-weight:800; letter-spacing:-.04em;
}
.score {
  margin-top:4px; color:var(--muted); font-size:14px;
}
.scorebar {
  margin-top:12px; height:10px; border-radius:999px; overflow:hidden;
  background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.08);
}
.scorefill {
  height:100%;
  background:linear-gradient(90deg, #7aa2ff 0%, #53c5c9 100%);
  border-radius:999px;
}
.spec-grid {
  margin-top:18px;
  display:grid; grid-template-columns:repeat(4,1fr); gap:12px;
}
.spec {
  border-radius:18px; padding:14px;
  border:1px solid var(--line); background:rgba(255,255,255,.52);
}
.spec span {
  display:block; font-size:12px; letter-spacing:.12em; text-transform:uppercase; color:var(--muted);
}
.spec strong {
  display:block; margin-top:8px; font-size:18px; line-height:1.35;
}
.proscons {
  margin-top:18px; display:grid; grid-template-columns:1fr 1fr; gap:14px;
}
.pane {
  border-radius:20px; padding:18px; border:1px solid var(--line);
}
.pane.good { background:rgba(73,184,143,.08); }
.pane.warn { background:rgba(208,123,134,.08); }
.pane-title {
  font-size:13px; letter-spacing:.14em; text-transform:uppercase; color:var(--muted); margin-bottom:10px;
}
.pane ul {
  margin:0; padding-left:18px; color:#dbe6f8; line-height:1.65; font-size:14px;
}
.meta-note {
  margin-top:14px; font-size:12px; color:var(--muted);
}

.table-wrap {
  overflow:auto; border-radius:28px; margin-top:18px;
  border:1px solid var(--line);
  background:rgba(255,255,255,.03);
}
.table {
  min-width:1100px;
  display:grid;
  grid-template-columns: 190px repeat(5, 1fr);
}
.tcell {
  padding:14px 16px; border-right:1px solid var(--line); border-bottom:1px solid var(--line);
  font-size:14px; line-height:1.5;
}
.tcell.head {
  background:rgba(122,162,255,.10); font-weight:700;
}
.tcell.colhead {
  font-size:13px; letter-spacing:.08em; text-transform:uppercase; font-weight:700;
  background:rgba(255,255,255,.05);
}
.tcell:last-child { border-right:none; }

.setup {
  margin-top:22px;
  border-radius:30px;
  padding:26px;
}
.setup-grid {
  display:grid; grid-template-columns: 1.05fr .95fr; gap:24px; align-items:center;
}
.diagram {
  border-radius:24px; border:1px solid var(--line); background:linear-gradient(180deg,#10192d,#0c1527);
  padding:22px;
}
.legend {
  display:flex; gap:10px; flex-wrap:wrap; margin-top:14px;
}
.legend .item {
  padding:8px 12px; border-radius:999px; border:1px solid var(--line); font-size:13px; background:rgba(255,255,255,.65);
}
.callouts {
  display:grid; gap:14px;
}
.callout {
  border-radius:20px; border:1px solid var(--line); background:rgba(255,255,255,.04); padding:16px;
}
.callout h4 {
  margin:0 0 8px; font-size:18px; letter-spacing:-.02em;
}
.callout p {
  margin:0; font-size:14px; line-height:1.65; color:#d7e2f4;
}

.footer {
  margin-top:26px;
  border-radius:24px;
  padding:18px 22px;
  color:#9fb0c9;
  font-size:12px;
  line-height:1.7;
}

.reveal {
  opacity:0;
  transform: translateY(18px) scale(.985);
  animation: rise .8s cubic-bezier(.2,.7,.2,1) forwards;
}
@keyframes rise {
  0% { opacity:0; transform: translateY(18px) scale(.985); filter: blur(6px); }
  100% { opacity:1; transform: translateY(0) scale(1); filter: blur(0); }
}
.float {
  animation: floaty 7s ease-in-out infinite;
}
@keyframes floaty {
  0%,100% { transform: translateY(0px); box-shadow: 0 18px 40px rgba(0,0,0,.18); }
  50% { transform: translateY(-10px); box-shadow: 0 28px 60px rgba(0,0,0,.24); }
}
.card, .panel, .setup, .hero, .footer {
  position: relative;
}
.card::after, .panel::after, .setup::after, .hero::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  background: linear-gradient(135deg, rgba(255,255,255,.06), transparent 28%, transparent 72%, rgba(83,197,201,.06));
  opacity: .9;
}
.card:hover {
  transform: translateY(-4px);
  transition: transform .35s ease, box-shadow .35s ease, border-color .35s ease;
  box-shadow: 0 30px 70px rgba(0,0,0,.28);
  border-color: rgba(122,162,255,.18);
}
.metric, .chip, .spec, .callout, .pricebox, .pane {
  transition: transform .28s ease, border-color .28s ease, background .28s ease, box-shadow .28s ease;
}
.metric:hover, .chip:hover, .spec:hover, .callout:hover, .pricebox:hover, .pane:hover {
  transform: translateY(-2px);
  border-color: rgba(122,162,255,.2);
  box-shadow: 0 16px 36px rgba(0,0,0,.18);
}

@media (max-width: 1100px) {
  .hero, .grid2, .setup-grid, .card-top, .proscons { grid-template-columns: 1fr; }
  .metric-grid { grid-template-columns:1fr; }
  .spec-grid { grid-template-columns:repeat(2,1fr); }
}
@media (max-width: 720px) {
  .page { width:min(100vw - 18px, 1440px); margin:10px auto 24px; }
  .hero, .panel, .setup, .card { padding:20px; }
  .spec-grid { grid-template-columns:1fr; }
}
</style>
</head>
